function threshold(input, output, file){
roiManager("reset");
open(input+File.separator+file);
title=getTitle();
  run("Properties...", "unit=um pixel_width="+scale+" pixel_height="+scale+" voxel_depth=1");
roiManager("reset");
run("Split Channels");
selectImage("C1-"+title);
setThreshold(1, 255);
run("Analyze Particles...", "pixel show=Masks add");
close("mask of C1-"+title);
selectImage("C2-"+title);
roiManager("deselect");
roiManager("Measure");
selectWindow("Results");
		for (i = 0; i < nResults; i++) {
		string1= string1+title+","+i+1+","+getResult("Area",i)+","+getResult("%Area",i)+"\n";
			       	}
	run("Clear Results");
	roiManager("reset");
	selectImage("C2-"+title);
setThreshold(1, 255);
run("Analyze Particles...", "pixel show=Masks add");
close("mask of C2-"+title);
	run("Clear Results");
selectImage("C1-"+title);
resetThreshold;
roiManager("Measure");	
selectWindow("Results");
		for (i = 0; i < nResults; i++) {
		string2= string2+title+","+i+1+","+getResult("Area",i)+","+getResult("%Area",i)+"\n";
			       	}
	run("Clear Results");
}
			 
